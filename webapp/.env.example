# ── Telegram Bot ────────────────────────────────────────────────────────────
#
# 1. Crie um bot com o @BotFather no Telegram e copie o token gerado:
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 2. Descubra o chat_id do seu usuário (ou grupo):
#    - Envie uma mensagem para o bot
#    - Acesse: https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
#    - Copie o valor de "id" dentro de "chat"
TELEGRAM_CHAT_ID=123456789

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false